# Django Backend Environment Variables
# Copy this file to .env and replace placeholders with actual values

# Django Secret Key
SECRET_KEY=your-django-secret-key-here  # Generate using https://djecrety.ir/

# Debug Mode
DEBUG=True

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration (PostgreSQL)
DB_NAME=pharmacy_aggregator
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Supabase / managed Postgres (recommended)
# If you set DATABASE_URL, it will be used instead of DB_* above.
# Get this from Supabase: Project Settings -> Database -> Connection string (URI)
# Example:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres
DATABASE_URL=

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Settings (SimpleJWT)
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME=15 minutes
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME=1 day

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# M-Pesa (Daraja API) Configuration
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=http://localhost:8000/api/payments/mpesa/callback/
MPESA_CONFIRMATION_URL=http://localhost:8000/api/payments/mpesa/confirmation/
MPESA_VALIDATION_URL=http://localhost:8000/api/payments/mpesa/validation/
MPESA_ENVIRONMENT=sandbox  # Use 'production' for live

# AWS S3 Configuration (for file storage, e.g., prescriptions)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
AWS_S3_REGION_NAME=us-east-1  # Change to your region

# Supabase Storage (S3-compatible) - optional
# Turn this on only when your S3-compatible storage values are set.
USE_S3=False
# Endpoint example:
# AWS_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
AWS_S3_ENDPOINT_URL=
# Set to True if you want signed/private file URLs.
AWS_QUERYSTRING_AUTH=False

# Email Configuration (for order notifications, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password

# Logging
LOGGING_LEVEL=INFO
